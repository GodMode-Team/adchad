# AdChad env — copy real values into .env.local (gitignored)
FOREPLAY_API_KEY=          # ✅ already set
DATABASE_URL=              # Neon: postgres://user:pass@host/db?sslmode=require   (Spec 01)
OPENROUTER_API_KEY=        # openrouter.ai/keys — covers Hermes-4 + Nemotron + Grok (Spec 03-04)
X_API_KEY=                 # X API consumer key (from the team) (Spec 04)
X_API_SECRET=              # X API consumer secret
X_ACCESS_TOKEN=            # X API user access token (write/user-context)
X_ACCESS_SECRET=           # X API user access token secret
RESEND_API_KEY=            # resend.com — also verify a sending domain (Spec 04)
RESEND_FROM=roast@adchad.ai
BRAVE_API_KEY=             # optional booster — Brave Search (free tier) for biz-name→website on link-less ads
STRIPE_SECRET_KEY=         # sk_test_...  (Spec 05)
STRIPE_PUBLISHABLE_KEY=    # pk_test_...
STRIPE_WEBHOOK_SECRET=     # whsec_...  (from `stripe listen`)
APP_URL=http://localhost:3000
# model ids for the bake-off (via OpenRouter)
MODEL_ROAST=nousresearch/hermes-4-405b
MODEL_SCORE=nvidia/nemotron-3-super-120b-a12b
MODEL_IMAGE=google/gemini-2.5-flash-image   # ad creative via OpenRouter (no separate image key needed)
